# *.xsa
# *.xpfm

# ------------------------------------------------------------
# PetaLinux generated files
# Keep project-spec/, configs, patches, recipes, and scripts.
# Ignore build outputs, images, and workspace junk.
# ------------------------------------------------------------
petalinux/**/.petalinux/
petalinux/**/build/
petalinux/**/images/linux/
petalinux/**/pre-built/
petalinux/**/components/plnx_workspace/
petalinux/**/components/yocto/workspace/
